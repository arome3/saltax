# =============================================================================
# SaltaX Environment Configuration
# Copy this file to .env and fill in the values.
# Secrets (marked KMS-sealed) are sealed via EigenCloud KMS in production.
# =============================================================================

# --- EigenAI Determinal Grant Auth ---
SALTAX_EIGENAI_GRANT_API_URL=https://determinal-api.eigenarcade.com
SALTAX_EIGENAI_WALLET_PRIVATE_KEY=0x...your-private-key    # KMS-sealed in production
SALTAX_EIGENAI_WALLET_ADDRESS=0x...your-wallet-address
SALTAX_EIGENAI_API_URL=https://eigenai.eigencloud.xyz/v1

# --- GitHub App ---
SALTAX_GITHUB_APP_ID=123456
SALTAX_GITHUB_APP_PRIVATE_KEY=base64-encoded-pem           # KMS-sealed in production
SALTAX_GITHUB_WEBHOOK_SECRET=your-webhook-secret            # KMS-sealed in production

# --- Base Chain (Treasury / Stablecoin) ---
SALTAX_RPC_URL=https://mainnet.base.org
SALTAX_CHAIN_ID=8453

# --- Ethereum (ERC-8004 Identity) ---
SALTAX_IDENTITY_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SALTAX_IDENTITY_CHAIN_ID=11155111

# --- EigenCloud KMS ---
SALTAX_EIGENCLOUD_KMS_ENDPOINT=https://kms.eigencloud.xyz

# --- Logging ---
SALTAX_LOG_LEVEL=INFO

# --- Server ---
SALTAX_HOST=0.0.0.0
SALTAX_PORT=8080
SALTAX_INTERNAL_BRIDGE_PORT=8081
